{
  "name": "leetcode-roadmap",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"node server.js\" \"npm --prefix frontend run dev\"",
    "build:frontend": "npm --prefix frontend run build -- --outDir ../release/dist",
    "build:exe": "npx pkg server.js --targets node18-win-x64 --output \"release/LeetCode Roadmap\" --compress GZip",
    "build": "npm run build:frontend && npm run build:exe",
    "install:all": "npm install && npm --prefix frontend install"
  },
  "pkg": {
    "targets": ["node18-win-x64"]
  },
  "dependencies": {
    "express": "^4.18.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.11.5",
    "concurrently": "^8.2.2"
  }
}
