{
  "manifest_version": 3,
  "name": "LeetCode Roadmap Connector",
  "version": "1.0",
  "description": "One-click connect your LeetCode account to the local Roadmap app.",
  "permissions": ["cookies"],
  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:3001/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  }
}
